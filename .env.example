# AgentOS Configuration
# Copy this file to .env and adjust values for your environment.

# LLM Model Router
AGENTOS_LLM_BASE_URL=http://localhost:8080
AGENTOS_LLM_TIMEOUT=120000
AGENTOS_LLM_MAX_RETRIES=3
# AGENTOS_LLM_API_KEY=your-api-key-here

# Connectivity health check endpoint
AGENTOS_HEALTH_CHECK_URL=https://httpbin.org/head

# Swarm configuration
AGENTOS_SWARM_MAX_WORKERS=10
AGENTOS_SWARM_MAX_RETRIES=3
AGENTOS_SWARM_VALIDATION_THRESHOLD=0.7
AGENTOS_SWARM_VALIDATORS_PER_RESULT=3

# Data storage
AGENTOS_DATA_DIR=.agentos

# Logging
AGENTOS_LOG_LEVEL=info