{
  "name": "@agentos/capabilities",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@agentos/types": "workspace:*",
    "@agentos/kernel": "workspace:*",
    "@agentos/eventstore": "workspace:*",
    "@agentos/resources": "workspace:*",
    "@agentos/memory": "workspace:*",
    "@agentos/llm": "workspace:*"
  },
  "devDependencies": {
    "@agentos/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
