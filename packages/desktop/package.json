{
  "name": "@agentos/desktop",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@agentos/types": "workspace:*",
    "@agentos/capabilities": "workspace:*"
  },
  "peerDependencies": {
    "@nut-tree-fork/nut-js": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@nut-tree-fork/nut-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentos/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}