{
  "name": "@agentos/types",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./zod": {
      "import": "./dist/zod/index.js",
      "types": "./dist/zod/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@agentos/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}