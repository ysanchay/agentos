{
  "name": "@agentos/simulation",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "start": "node --import tsx src/cli/index.ts --agents 100"
  },
  "dependencies": {
    "@agentos/blackboard": "workspace:*",
    "@agentos/eventstore": "workspace:*",
    "@agentos/kernel": "workspace:*",
    "@agentos/protocol": "workspace:*",
    "@agentos/resources": "workspace:*",
    "@agentos/types": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@agentos/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}